<li class="list-none border-b border-gray-100 py-3 px-1 last:border-b-0 cursor-pointer rounded-md hover:bg-gray-50 focus-within:bg-gray-50 outline-none"
  data-map-item-id="<%= map_item_id %>"
  role="button"
  tabindex="0"
  aria-label="Open <%= item_name %> on the map">
  <h3 class="text-base font-semibold leading-snug text-gray-900"><%= item_name %></h3>
  <div class="mt-1 flex flex-row flex-wrap items-center gap-x-4 gap-y-0.5 text-sm text-gray-600">
    <span class="min-w-0 truncate"><%= item_type %></span>
    <a class="min-w-0 truncate text-blue-600 underline hover:text-blue-800" href="<%= item_link %>">Visit Site</a>
  </div>
</li>
