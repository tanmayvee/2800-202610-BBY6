  <%- include("templates/header")%>
    <link href="https://unpkg.com/maplibre-gl@5.24.0/dist/maplibre-gl.css" rel="stylesheet" />
  </head>
  <body>
    <%- include("./tutorial.ejs", {showTutorial: showTutorial})%>
    <div class="flex flex-col h-screen w-full relative">
      <main class="h-full w-full relative">
        <!-- Map -->
        <div id="map" class="h-full w-full"></div>

        <!-- Filter Drawer -->
        <div id="filter-drawer">        
            <div class="flex justify-center mb-4">
                <div class="w-60 h-1 bg-gray-300 rounded-full"></div>
            </div> 
            <h2 class="text-lg text-center font-semibold mb-4">Shade Filters<h2>                  
            <div class="flex flex-col items-center">
                <nav id="nav-filter" class="flex flex-col gap-2">                   
                    <div>
                        <input type="checkbox" name="layer-filter" id="parks" class="sr-only peer" />
                        <label for="parks" class="block px-5 py-3 rounded-xl border border-gray-200 text-gray-500 text-[15px] cursor-pointer peer-checked:bg-gray-100 peer-checked:text-gray-900 peer-checked:border-gray-400 peer-focus-visible:ring-2">Parks</label>
                    </div>
                    <div>
                        <input type="checkbox" name="layer-filter" id="cooling-centres" class="sr-only peer" />
                        <label for="cooling-centres" class="block px-5 py-3 rounded-xl border border-gray-200 text-gray-500 text-[15px] cursor-pointer peer-checked:bg-gray-100 peer-checked:text-gray-900 peer-checked:border-gray-400 peer-focus-visible:ring-2">Cooling Centres</label>
                    </div>
                </nav>
                <button id="clear-filters" class="hidden filter-btn text-left mt-6 block px-5 py-3 rounded-xl border border-gray-200 text-gray-500 text-[15px] cursor-pointer">Clear all</button>
            </div>
        </div>

        <!-- Drawer -->
        <div id="drawer" class="flex flex-col">
          <div class="flex justify-between items-center">
            <div id="drawer-title" class="text-xl font-bold"></div>
            <button id="drawer-close" class="bg-gray-600 text-white px-3 py-1 rounded-md" onclick="closeDrawer()">✕</button>
          </div>
          <div id="drawer-content" class="flex-1"></div>
          <div class="flex flex-col gap-2 mt-4 max-w-md mx-auto w-full">
            <button class="bg-blue-600 text-white px-4 py-3 rounded-md font-semibold text-lg">Go Here</button>
            <button class="bg-gray-600 text-white px-4 py-2 rounded-md">Save</button>
          </div>
        </div>

        <!-- Filter Button -->
        <button id="filter-btn" class="absolute rounded-2xl z-[9998] bottom-12 left-6 p-3 bg-white hover:bg-gray-100 cursor-pointer transition">
          <img class="btn-icon" src="/img/filter.svg" alt="Filter" draggable="false" />
        </button>

        <!-- Floating temp/uv -->
        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-[1000]">
          <div id="floating-temp" class="bg-white/90 backdrop-blur-sm rounded-2xl shadow-xl border border-gray-200 text-center">
            <span class="text-xs font-bold tracking-wider text-gray-500 block mb-1">Current Temperature</span>
            <p id="temp" class="text-2xl font-bold">--°C</p>
            <p id="uv" class="text-sm font-medium text-gray-700">UV: --</p>
          </div>
        </div>

        <!-- Settings Button -->
        <a id="settings-btn" href="/usersettings" class="absolute rounded-2xl z-[9998] bottom-12 right-6 p-3 bg-white cursor-pointer hover:bg-gray-100 transition">
          <img class="btn-icon" src="/img/settings.svg" alt="Settings" draggable="false" />
        </a>
      </main>
    </div>

    <script>window.MAPTILER_KEY = "<%= maptilerKey %>";</script>
    <script src="https://unpkg.com/maplibre-gl@5.24.0/dist/maplibre-gl.js"></script>
    <script src="/js/main.js"></script>
    <script src="/js/map.js"></script>
  </body>
</html>