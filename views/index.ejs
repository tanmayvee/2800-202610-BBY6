<%- include('templates/header', { cssFiles: cssFiles }) %>

    <%- include("./tutorial.ejs", {showTutorial: showTutorial})%>
    
    <div class="flex flex-col h-screen w-full relative">
      <main class="h-full w-full relative">

        <!-- Map -->
        <div id="map" class="h-full w-full"></div>

        <!-- Filter  -->
        <%- include("filter.ejs") %>

        <!-- Parks/Cooling Centres Info -->
        <%- include("parks-centres.ejs") %>

        <!-- Uv Info button -->
        <%- include("uv-info.ejs") %>

        <!-- Filter Button -->
        <button id="filter-btn" class="absolute rounded-2xl z-[9998] bottom-6 left-6 p-3 bg-white hover:bg-gray-100 transition">
          <img src="/img/filter.svg" alt="Filter" style="width: 50px; height: 50px;" />
        </button>

        <!-- Floating temp/uv -->
        <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-[1000]">
          <div class="bg-white/90 backdrop-blur-sm p-4 rounded-2xl shadow-xl border border-gray-200 text-center">
            <span class="text-xs font-bold tracking-wider text-gray-500 block mb-1">Current Temp</span>
            <p id="temp" class="text-2xl font-bold">--°C</p>
            <p id="uv" class="text-sm font-medium text-gray-700">UV: --</p>
          </div>
        </div>

        <!-- Settings Button -->
        <a id="settings-btn" href="/usersettings" class="absolute rounded-2xl z-[9998] bottom-12 right-6 p-3 bg-white cursor-pointer hover:bg-gray-100 transition">
          <img class="btn-icon" src="/img/settings.svg" alt="Settings" draggable="false" />
        </a>
      </main>
    </div>

<%- include('templates/footer', { jsFiles: jsFiles }) %>