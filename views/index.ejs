<%- include('templates/header', { cssFiles: cssFiles }) %>

    <%- include("./tutorial.ejs", {showTutorial: showTutorial})%>
    
    <div class="flex flex-col h-screen w-full relative">
      <%- include("./templates/search-pane.ejs") %>

      <main class="h-full w-full relative">

        <!-- Map -->
        <div id="map" class="h-full w-full"></div>

        <div id="drawer" class="flex flex-col">
          <div class="flex justify-between items-center">
            <div id="drawer-title" class="text-xl font-bold"></div>
            <button id="drawer-close" class="bg-gray-600 text-white px-3 py-1 rounded-md" onclick="closeDrawer()">
              ✕
            </button>
          </div>
          <div id="drawer-content" class="flex-1"></div>
          <div id="drawer-crowding-row" class="hidden mt-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-800"
            role="status" aria-live="polite">
            <span class="font-medium text-gray-600">People checked in here:</span>
            <span id="drawer-crowding-count" class="ml-1 font-semibold text-gray-900">—</span>
          </div>
          <div class="flex flex-col gap-2 mt-4 max-w-md mx-auto w-full">
            <button id="current-location-button" class="bg-blue-600 text-white px-4 py-3 rounded-md font-semibold text-lg">
              Go Here
            </button>
            <button class="bg-gray-600 text-white px-4 py-2 rounded-md">
              Save
            </button>
          </div>
        </div>

        <!-- Filter  -->
        <%- include("filter.ejs") %>

        <!-- Current Temp/UV  -->
        <%- include("current-temp-uv.ejs") %>    
        
        <%- include("parks-centres.ejs") %>

        <!-- Chat Modal -->
        <%- include("templates/chat-modal.ejs") %>

        <!-- Uv Info button -->
        <%- include("uv-info.ejs") %>
                     
        <!-- Settings Button -->
        <a id="settings-btn" href="/settings" class="absolute rounded-2xl z-[9998] bottom-6 right-6 p-3 cursor-pointer transition">
          <img class="btn-icon" src="/img/settings.svg" alt="Settings" draggable="false" />
        </a>
      </main>
    </div>

<%- include('templates/footer', { jsFiles: jsFiles }) %>
